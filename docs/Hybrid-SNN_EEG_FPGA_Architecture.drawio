        </mxCell>
        <mxCell id="hl_lane" value="&lt;b&gt;HLS Phase-1: hybrid_lif_head_q12_6&lt;/b&gt;  &lt;font style=&quot;font-size:9px;color:#666&quot;&gt;(Q12.6 定点, xc7z020-clg400-1, 每次调用处理 1 个样本)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8f0;strokeColor=#d79b00;dashed=1;dashPattern=8 4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;arcSize=3;fontSize=12;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="40" y="305" width="1200" height="430" as="geometry" />
        </mxCell>
        <mxCell id="hls_reset" value="&lt;b&gt;状态清零&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;membrane_q[32] = 0&lt;br&gt;spike_count[32] = 0&lt;br&gt;&lt;i&gt;每次 top function 调用前&lt;br&gt;状态不跨样本/被试继承&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#d79b00;arcSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="75" y="355" width="165" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hls_lif" value="&lt;b&gt;32 路并行 LIF 更新&lt;/b&gt;  &lt;font style=&quot;font-size:9px;color:#666&quot;&gt;&#x00D7; 48 步 (t = 0...47)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3edf7;strokeColor=#9673a6;arcSize=5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="275" y="340" width="330" height="290" as="geometry" />
        </mxCell>
        <mxCell id="lif_decay" value="&lt;b&gt;膜电位衰减&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;decayed = (58 &#x00D7; membrane_q) &#x00F7; 64&lt;br&gt;&#x3B2;_q = 58 (&#x2248; 0.90625, Q12.6)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="378" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="lif_integ" value="&lt;b&gt;电流积分&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;membrane_q = decayed + I_q[t][c]&lt;br&gt;I_q = feature_current_q (Q12.6, ap_int&lt;12&gt;)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="448" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="lif_spike" value="&lt;b&gt;阈值比较 + 脉冲发放&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;spike = (membrane_q &#x2265; 32)&lt;br&gt;thr_q = 32 (= 0.5, Q12.6)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="518" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="lif_rst" value="&lt;b&gt;Subtract&lt;br&gt;Reset&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#555&quot;&gt;membrane_q -= 32&lt;br&gt;if spike=1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#d79b00;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="540" y="505" width="50" height="70" as="geometry" />
        </mxCell>
        <mxCell id="le1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=1.2;endArrow=block;endFill=1;html=1;" edge="1" source="lif_decay" target="lif_integ" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=1.2;endArrow=block;endFill=1;html=1;" edge="1" source="lif_integ" target="lif_spike" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le_ctrl" value="&lt;font style=&quot;font-size:8px&quot;&gt;S=1&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#d79b00;strokeWidth=1;endArrow=block;endFill=1;dashed=1;dashPattern=4 3;html=1;labelBackgroundColor=#ffffff;" edge="1" source="lif_spike" target="lif_rst" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="565" y="545" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="le_loop" value="&lt;font style=&quot;font-size:8px;color:#d79b00&quot;&gt;t &#x2192; t+1&lt;/font&gt;" style="curved=1;orthogonalLoop=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#d79b00;strokeWidth=1.5;endArrow=block;endFill=1;dashed=1;dashPattern=6 4;html=1;labelBackgroundColor=#ffffff;" edge="1" source="lif_rst" target="lif_decay" parent="1">
