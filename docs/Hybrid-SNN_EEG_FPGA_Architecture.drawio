        <mxCell id="he4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333;strokeWidth=1.5;endArrow=block;endFill=1;html=1;" edge="1" source="hls_rate" target="hls_linear" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="he5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333;strokeWidth=1.5;endArrow=block;endFill=1;html=1;" edge="1" source="hls_linear" target="hls_out" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="clock_box" value="&lt;b&gt;时钟与证据边界&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;arcSize=5;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="755" width="600" height="165" as="geometry" />
        </mxCell>
        <mxCell id="clock_content" value="&lt;font style=&quot;font-size:9px;color:#444&quot;&gt;&lt;b&gt;HLS-3 综合约束:&lt;/b&gt; 10 ns / 100 MHz (C 综合阶段的可行性约束)&lt;br&gt;&#x2022; Estimated clock = 7.249 ns, Fmax &#x2248; 137.95 MHz, Slack = 0.05 ns&lt;br&gt;&#x2022; Top latency = 1688 cycles &#x2248; 16.88 &#x3BC;s @ 100 MHz&lt;br&gt;&#x2022; 资源: DSP=33(15%), FF=1980(1%), LUT=2405(4%), BRAM=0, URAM=0&lt;br&gt;&lt;br&gt;&lt;b&gt;CNN-LSTM Vivado 系统实际 PS FCLK_CLK0:&lt;/b&gt; 20 ns / 50 MHz&lt;br&gt;&#x2022; 50 MHz 是后续复用 CNN-LSTM Vivado 系统时的实际 PL 时钟&lt;br&gt;&#x2022; 1688 cycles @ 50 MHz = 33.76 &#x3BC;s&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;&#x26A0; 100 MHz 综合通过 &#x2260; 板端已运行在 100 MHz&lt;/b&gt;&lt;/font&gt;&lt;br&gt;当前仍未完成 Vivado implementation 和板端回放&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="773" width="580" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ny_box" value="&lt;b&gt;尚未完成 (Not Yet Implemented)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#888&quot;&gt;&#x2022; AXI / DMA 接口&lt;br&gt;&#x2022; Vivado Block Design&lt;br&gt;&#x2022; Bitstream 生成&lt;br&gt;&#x2022; 板端回放 (Board replay)&lt;br&gt;&#x2022; 功耗测量 (Power measurement)&lt;br&gt;&#x2022; EEG 数据集准确率测量&lt;br&gt;&#x2022; 片上 ROM 绑定模型常量&lt;br&gt;&#x2022; CNN / GroupNorm 前端 HLS 化&lt;br&gt;&#x2022; 50 MHz Vivado 集成 (HLS-5)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;dashPattern=6 4;arcSize=5;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=10;fontColor=#666;" vertex="1" parent="1">
