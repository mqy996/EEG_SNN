        <mxCell id="layout_tr" value="&lt;b&gt;布局转置&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;[32, 48] &#x2192; [48][32]&lt;br&gt;channel-first &#x2192; time-first&lt;br&gt;&lt;i&gt;仅转置, 不改数值&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
