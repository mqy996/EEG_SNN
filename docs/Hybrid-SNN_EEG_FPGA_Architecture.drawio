              <mxPoint x="535" y="373" />
              <mxPoint x="535" y="405" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="hls_sc" value="&lt;b&gt;脉冲计数&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;spike_count[32]&lt;br&gt;count_t: ap_uint&lt;6&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="640" y="370" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="hls_rate" value="&lt;b&gt;脉冲频率&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;rate_q[32]&lt;br&gt;= round(count&#x00D7;64/48)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="640" y="465" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="hls_linear" value="&lt;b&gt;冻结 Linear(32, 2)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;logits_q[k] = round(&lt;br&gt;&#x3A3; rate_q[c]&#x00D7;W_q[k][c] / 64&lt;br&gt;) + bias_q[k]&lt;br&gt;&lt;i&gt;Q12.6 整数运算, 无 softmax&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="825" y="405" width="190" height="100" as="geometry" />
        </mxCell>
        <mxCell id="wb_const" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;版本化模型常量&lt;/b&gt;&lt;br&gt;weight_q[2][32]  Q12.6&lt;br&gt;bias_q[2]  Q12.6&lt;br&gt;&lt;i&gt;只读, 非运行时加载&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;arcSize=8;verticalAlign=top;align=left;spacingLeft=6;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="840" y="520" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="wb_arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#d6b656;strokeWidth=1.2;endArrow=block;endFill=1;dashed=1;dashPattern=5 3;html=1;" edge="1" source="wb_const" target="hls_linear" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="hls_out" value="&lt;b&gt;输出&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;logits_q[2]&lt;br&gt;Q12.6, ap_int&lt;18&gt;&lt;br&gt;&lt;i&gt;读取: value / 64.0&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1055" y="425" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="he1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333;strokeWidth=1.5;endArrow=block;endFill=1;html=1;" edge="1" source="hls_reset" target="hls_lif" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="he2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333;strokeWidth=1.5;endArrow=block;endFill=1;html=1;" edge="1" source="hls_lif" target="hls_sc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="he3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333;strokeWidth=1.5;endArrow=block;endFill=1;html=1;" edge="1" source="hls_sc" target="hls_rate" parent="1">
          <mxGeometry relative="1" as="geometry" />
