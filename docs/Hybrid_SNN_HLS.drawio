        </mxCell>
        <mxCell id="lif_integ" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=14;verticalAlign=middle;align=center;" value="&lt;b&gt;电流积分&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;membrane_q = decayed + I_q[t][c]&lt;br&gt;I_q = feature_current_q (Q12.6, ap_int&lt;12&gt;)&lt;/font&gt;" vertex="1">
