        <mxCell id="hls_rate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=12;verticalAlign=middle;align=center;" value="&lt;b&gt;脉冲频率&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;rate_q[32]&lt;br&gt;= round(count×64/48)&lt;/font&gt;" vertex="1">
