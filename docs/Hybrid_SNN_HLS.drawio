        <mxCell id="hls_lif" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3edf7;strokeColor=#9673a6;arcSize=5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fontSize=11;fontColor=#333;" value="&lt;b&gt;32 路并行 LIF 更新&lt;/b&gt;  &lt;font style=&quot;font-size:9px;color:#666&quot;&gt;× 48 步 (t = 0...47)&lt;/font&gt;" vertex="1">
