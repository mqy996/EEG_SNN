        <mxCell id="hls_linear" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=12;verticalAlign=middle;align=center;" value="&lt;b&gt;冻结 Linear(32, 2)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;logits_q[k] = round(&lt;br&gt;Σ rate_q[c]×W_q[k][c] / 64&lt;br&gt;) + bias_q[k]&lt;br&gt;&lt;i&gt;Q12.6 整数运算, 无 softmax&lt;/i&gt;&lt;/font&gt;" vertex="1">
