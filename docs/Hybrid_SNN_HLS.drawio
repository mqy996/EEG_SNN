        <mxCell id="hls_reset" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#d79b00;arcSize=12;verticalAlign=middle;align=center;" value="&lt;b&gt;状态清零&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;membrane_q[32] = 0&lt;br&gt;spike_count[32] = 0&lt;br&gt;&lt;i&gt;每次 top function 调用前&lt;br&gt;状态不跨样本/被试继承&lt;/i&gt;&lt;/font&gt;" vertex="1">
