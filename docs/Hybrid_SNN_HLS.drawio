        <mxCell id="lif_decay" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=14;verticalAlign=middle;align=center;" value="&lt;b&gt;膜电位衰减&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;decayed = (58 × membrane_q) ÷ 64&lt;br&gt;β_q = 58 (≈ 0.90625, Q12.6)&lt;/font&gt;" vertex="1">
