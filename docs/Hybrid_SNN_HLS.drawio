        <mxCell id="he3" edge="1" parent="1" source="hls_sc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333;strokeWidth=1.5;endArrow=block;endFill=1;html=1;" target="hls_rate">
