        <mxCell id="dl_desc" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;" value="&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;• 相邻步&lt;b&gt;差值&lt;/b&gt;超阈值才产生事件&lt;br&gt;• 非常稀疏, 大部分时间步无事件&lt;br&gt;• 需维护 reference 状态&lt;br&gt;• 计算开销最高 (ops/value = 4.0)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="330" x="810" y="690" as="geometry" />
        </mxCell>
        <mxCell id="footer" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];strokeColor=none;fillColor=none;" value="&lt;font style=&quot;font-size:10px;color:#888&quot;&gt;结论: DC 编码以最低计算开销保留完整时域信息, 是 Hybrid-SNN 的冻结基线选择&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="420" x="380" y="870" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
